# Age of Agents Server Configuration
PORT=5173
NODE_ENV=development

# Session Sources (comma-separated: claude,codex,opencode,koda)
AOA_SOURCES=claude,codex,opencode,koda

# Demo Mode
AOA_DEMO=false

# Codex Lookback (days)
AOA_CODEX_LOOKBACK_DAYS=7

# Local LLM Proxy
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llama3
# LLM_API_KEY=

# Security
AOA_ALLOW_REMOTE=false
